FROM python:3.9-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    curl \
    libsndfile1 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Download the emotion model
RUN python -c "from transformers import AutoModel, AutoFeatureExtractor; \
    model = AutoModel.from_pretrained('SuperKogito/HSEmotion-onnx'); \
    feat_ext = AutoFeatureExtractor.from_pretrained('SuperKogito/HSEmotion-onnx')" || echo "Model download optional"

# Copy application code
COPY . .

# Expose port
EXPOSE 5000

# Health check
HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
    CMD curl --fail http://localhost:5000/health || exit 1

# Run the application
CMD ["python", "api.py"]
